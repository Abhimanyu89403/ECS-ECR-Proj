pipeline {
    agent any

        environment {
            AWS_REGION = "ap-south-1"
            TF_VERSION = ">~ 1.6.0"
            AWS_ACCESS_KEY_ID = credentials ('aws-access-key-id')
            AWS_SECRET_ACCESS_KEY_ID = credentnials('aws-secret-access-key')
        }
    
    stages {
        stage ('Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage ('Set Environment') {
            steps {
                script {
                    if (env.BRANCH_NAME == 'dev'){
                        env.ENV ="dev"
                    }
                    else if (env.BRANCH_NAME == "stage"){
                        env.ENV = "stage"
                    }
                    else if (env.BRANCH_NAME == 'prod'){
                        env.ENV = "prod"
                    }else {
                        error (" Unsupported branch: ${env.BRANCH_NAME} ")
                    }
                }
            }
        }
        stage ('initiate terraform'){
            steps {
                bat 'terraform init'
            }
        }
        stage ('validate terraform'){
            steps {
                bat 'terraform validate'
            }
        }
        stage ('plan terraform state file'){
            steps {
                bat "terraform plan -var-file=${env.ENV}.tfvars -out=tfplan"
                bat "terraform show tfplan"
            }
        }
        stage ('approval only for prod'){
            when {
                expression {env.ENV == 'prod'}
            }
            steps {
                input message : "approve terraform apply for prod"
            }
        }
        stage ('apply the infra') {
            steps {
                bat 'terraform apply -auto-approve tfplan'
                }
        }
    }
}